# =============================================================================
# muuney.hub — environment variables reference
# =============================================================================
# Copy this file to `.env.local` and fill in real values. Do NOT commit .env.local.
# Vite only exposes variables prefixed with `VITE_` to the browser bundle.
# =============================================================================

# ─── Supabase (frontend) ───────────────────────────────────────────────────
# Project: yheopprbuimsunqfaqbp
# Dashboard: https://supabase.com/dashboard/project/yheopprbuimsunqfaqbp/settings/api
VITE_SUPABASE_URL=https://yheopprbuimsunqfaqbp.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# ─── Sentry (optional — frontend error tracking) ──────────────────────────
# If unset, errorTracking.ts falls back to console-only logging.
# Get DSN from: https://sentry.io/settings/<org>/projects/<proj>/keys/
# VITE_SENTRY_DSN=https://<key>@sentry.io/<project-id>
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=muuney-hub@<git-sha>

# =============================================================================
# Edge Function secrets (Supabase Dashboard → Settings → Edge Functions)
# These are NOT used by the Vite build. They live server-side in Supabase
# and are documented here for ops reference only.
# =============================================================================

# ─── Supabase service role (auto-provided by Supabase runtime) ────────────
# SUPABASE_URL=...                   # auto
# SUPABASE_ANON_KEY=...              # auto
# SUPABASE_SERVICE_ROLE_KEY=...      # auto

# ─── Site URL (used by stripe-checkout + invite-beta-user) ────────────────
# SITE_URL=https://hub.muuney.com.br

# ─── Resend (send-email-hook) ─────────────────────────────────────────────
# RESEND_API_KEY=re_...
# SEND_EMAIL_HOOK_SECRET=...         # Supabase Auth hook HMAC secret

# ─── Stripe (stripe-checkout + stripe-webhook) ────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...       # or sk_test_... during staging
# STRIPE_PRICE_ID_MONTHLY=price_...   # R$49/mês product price id
# STRIPE_PRICE_ID_YEARLY=price_...    # R$490/ano product price id
# STRIPE_WEBHOOK_SECRET=whsec_...     # from Stripe Dashboard webhook endpoint
